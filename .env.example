APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=tenant_central
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

TENANT_CENTRAL_DB_CONNECTION=sqlite
TENANT_CENTRAL_DB_DATABASE=/absolute/path/to/database/database.sqlite

TENANT_JYM_DB_CONNECTION=sqlite
TENANT_JYM_DB_DATABASE=/absolute/path/to/database/tenant_jym.sqlite

TENANT_CASA_ANGEL_DB_CONNECTION=sqlite
TENANT_CASA_ANGEL_DB_DATABASE=/absolute/path/to/database/tenant_casa_angel.sqlite

TENANT_SPORT_BOGOTA_DB_CONNECTION=sqlite
TENANT_SPORT_BOGOTA_DB_DATABASE=/absolute/path/to/database/tenant_sport_bogota.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# CORS
# Desarrollo: agrega localhost y/o tu frontend local.
# Produccion: reemplaza por los dominios finales permitidos.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://dinamycode.com,https://www.dinamycode.com,https://eventoscasaangel.com,https://www.eventoscasaangel.com,https://vidriosyestructurasjym.com,https://www.vidriosyestructurasjym.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,Origin,X-Requested-With
CORS_MAX_AGE=0
CORS_SUPPORTS_CREDENTIALS=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
